<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_fleet_sales_commission" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.fleet.sales.commission</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Fleet Sales" name="fleet_sales_app" groups="sales_team.group_sale_manager">
                    <block title="Fleet Sales Commission">
                        <setting string="Default Commission Mode"
                                 help="Default commission mode for new Sales Orders. Can be changed per order.">
                            <field name="commission_mode"/>
                        </setting>
                        <setting string="Default Timesheet Project"
                                 help="Used for auto-created tasks and timesheets from assigned service order lines.">
                            <field name="timesheet_project_id"/>
                        </setting>
                        <setting string="Service Reminder Webhook URL"
                                 help="Used only when provider is Generic Webhook. POST requests with vehicle/service context are sent to this URL 3 days before each Next Service Date.">
                            <field name="service_reminder_webhook_url" widget="url" placeholder="https://…"/>
                        </setting>
                        <setting string="Service Reminder Provider"
                                 help="Choose Generic Webhook or Evolution API for automatic reminders.">
                            <field name="service_reminder_provider"/>
                        </setting>
                        <setting string="Reminder Days Before Service"
                                 help="How many days before Next Service Date the reminder should be sent.">
                            <field name="service_reminder_days"/>
                        </setting>
                        <setting string="Evolution Base URL"
                                 help="Base URL of your Evolution server, for example https://evolution.cashfloo.com.">
                            <field name="evolution_base_url" placeholder="https://evolution.cashfloo.com"/>
                        </setting>
                        <setting string="Evolution Instance Name"
                                 help="Instance used by endpoint /message/sendText/&lt;instance&gt;.">
                            <field name="evolution_instance_name" placeholder="my-instance"/>
                        </setting>
                        <setting string="Evolution API Key"
                                 help="Secret API key for Evolution requests.">
                            <field name="evolution_api_key" password="True" placeholder="Paste API key"/>
                        </setting>
                        <setting string="Default Country Code"
                                 help="Used to normalize phone numbers like 08... into international format.">
                            <field name="evolution_country_code" placeholder="62"/>
                        </setting>
                        <setting string="WhatsApp Message Template"
                                                                 help="Placeholders include {driver_name}, {customer_name}, {next_service_date}, {next_service_date_formatted}, {service_date}, {service_date_formatted}, {vehicle_name}, {vehicle_brand}, {vehicle_model}, {license_plate}, {service_type}, {sale_order}, {amount}, {currency}, {company_name}, {reminder_trigger}, {reminder_sent_at}.">
                            <field name="evolution_message_template"
                                   widget="text"
                                                                     placeholder="Halo Bapak/Ibu [Nama] 👋&#10;&#10;Kami dari [Nama Bengkel] ingin mengingatkan jadwal servis kendaraan Anda:&#10;&#10;1️⃣ Kendaraan: [Merk Mobil] ([No. Polisi])&#10;2️⃣ Servis terakhir: [Tanggal Servis Terakhir]&#10;3️⃣ Servis berikutnya: [Tanggal Servis Berikutnya]&#10;&#10;✅ Agar kendaraan tetap prima, kami sarankan booking servis sekarang.&#10;📞 Silakan hubungi kami untuk penjadwalan.&#10;&#10;Terima kasih 🙏"/>
                        </setting>
                        <setting string="Test WhatsApp Number"
                                 help="Use this to send a test message from module settings via Evolution API."
                                 invisible="service_reminder_provider != 'evolution'">
                            <field name="evolution_test_number" placeholder="08123456789"/>
                            <button name="action_test_evolution_whatsapp"
                                    string="Send Test WhatsApp"
                                    type="object"
                                    class="btn-secondary"
                                    invisible="not evolution_test_number"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_fleet_sales_commission" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.fleet.sales.commission</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Fleet Sales" name="fleet_sales_app" groups="sales_team.group_sale_manager">
                    <block title="Fleet Sales Commission">
                        <setting string="Enable Gross Commission"
                                 help="Allow GROSS commission modes and revenue commission input on Sales Orders.">
                            <field name="enable_gross_commission"/>
                        </setting>
                        <setting string="Commission Mode"
                                 help="Choose how Sales Order commission is calculated.">
                            <field name="commission_mode"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>

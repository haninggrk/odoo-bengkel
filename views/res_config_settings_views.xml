<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_fleet_sales_commission" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.fleet.sales.commission</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Fleet Sales" name="fleet_sales_app" groups="sales_team.group_sale_manager">
                    <block title="Fleet Sales Commission">
                        <setting string="Default Commission Mode"
                                 help="Default commission mode for new Sales Orders. Can be changed per order.">
                            <field name="commission_mode"/>
                        </setting>
                        <setting string="Default Timesheet Project"
                                 help="Used for auto-created tasks and timesheets from assigned service order lines.">
                            <field name="timesheet_project_id"/>
                        </setting>
                        <setting string="Service Reminder Webhook URL"
                                 help="POST requests with vehicle/service context are sent to this URL 3 days before each Next Service Date.">
                            <field name="service_reminder_webhook_url" widget="url" placeholder="https://…"/>
                        </setting>
                        <setting string="Service Reminder Provider"
                                 help="Choose Generic Webhook or Evolution API for automatic reminders.">
                            <field name="service_reminder_provider"/>
                        </setting>
                        <setting string="Evolution Base URL"
                                 help="Base URL of your Evolution server, for example https://evolution.cashfloo.com.">
                            <field name="evolution_base_url" placeholder="https://evolution.cashfloo.com"/>
                        </setting>
                        <setting string="Evolution Instance Name"
                                 help="Instance used by endpoint /message/sendText/&lt;instance&gt;.">
                            <field name="evolution_instance_name" placeholder="my-instance"/>
                        </setting>
                        <setting string="Evolution API Key"
                                 help="Secret API key for Evolution requests.">
                            <field name="evolution_api_key" password="True" placeholder="Paste API key"/>
                        </setting>
                        <setting string="Default Country Code"
                                 help="Used to normalize phone numbers like 08... into international format.">
                            <field name="evolution_country_code" placeholder="62"/>
                        </setting>
                        <setting string="Evolution Message Template"
                                 help="Placeholders include {driver_name}, {customer_name}, {next_service_date}, {service_date}, {vehicle_name}, {license_plate}, {service_type}, {sale_order}, {amount}, {currency}, {company_name}, {reminder_trigger}, {reminder_sent_at}.">
                            <field name="evolution_message_template" placeholder="Hello {customer_name}, your {service_type} service for {vehicle_name} ({license_plate}) is scheduled on {next_service_date}."/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>

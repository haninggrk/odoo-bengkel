<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_kedoo_sales_timesheet_assignment" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.kedoo.sales.timesheet.assignment</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Kedoo Sales" name="kedoo_sales_app" groups="sales_team.group_sale_manager">
                    <block title="Sales Timesheet Assignment">
                        <setting string="Default Timesheet Project"
                                 help="Used for auto-created tasks and timesheets from assigned service order lines.">
                            <field name="timesheet_project_id"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>

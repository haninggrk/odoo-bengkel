<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_kedoo_sales_timesheet_assignment" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.kedoo.sales.timesheet.assignment</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='product_template_id']" position="after">
                <field name="line_project_sales_group_id" column_invisible="1"/>
                <field name="line_allowed_employee_ids" column_invisible="1"/>
                <field name="assigned_employee_id"
                       optional="show"
                       readonly="display_type"
                       domain="line_project_sales_group_id and [('id', 'in', line_allowed_employee_ids)] or []"/>
                <field name="generated_task_id" optional="hide" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>

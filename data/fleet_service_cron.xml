<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Daily cron: send reminders (Webhook or Evolution) for services 3 days away -->
        <record id="ir_cron_fleet_service_reminder" model="ir.cron">
            <field name="name">Fleet Sales: Send Service Reminders</field>
            <field name="model_id" ref="fleet.model_fleet_vehicle_log_services"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_service_reminders()</field>
            <field name="interval_number">2</field>
            <field name="interval_type">minutes</field>
            <field name="active">1</field>
        </record>
    </data>
</odoo>

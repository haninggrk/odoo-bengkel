<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_kedoo_sales_commission" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.kedoo.sales.commission</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Kedoo Sales" name="kedoo_sales_app" groups="sales_team.group_sale_manager">
                    <block title="Sales Commission">
                        <setting string="Default Commission Mode"
                                 help="Default commission mode for new Sales Orders. Can be changed per order.">
                            <field name="commission_mode"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>

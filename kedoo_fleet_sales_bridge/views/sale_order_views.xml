<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_kedoo_fleet_bridge" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.kedoo.fleet.bridge</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="existing_fleet_vehicle_id"
                       placeholder="Select or create a vehicle..."
                       domain="['|', ('driver_id', '=', partner_id), ('driver_id', '=', False)]"
                       options="{'no_create': True, 'no_open': True}"/>
                <field name="service_type_id" placeholder="Select service type..."/>
            </xpath>

            <xpath expr="//field[@name='validity_date']" position="before">
                <field name="service_date"/>
            </xpath>

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_fleet_vehicle"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-car"
                        invisible="fleet_vehicle_count == 0">
                    <span>Vehicle Detail</span>
                </button>
                <button name="action_view_fleet_service"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-wrench"
                        invisible="fleet_service_count == 0">
                    <span>Service Detail</span>
                </button>
            </xpath>

            <xpath expr="//sheet" position="inside">
                <field name="fleet_vehicle_id" invisible="1"/>
                <field name="fleet_service_id" invisible="1"/>
                <field name="has_existing_vehicles" invisible="1"/>
                <field name="license_plate" invisible="1"/>
                <field name="fleet_vehicle_model_id" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_order_tree_inherit_kedoo_fleet_bridge" model="ir.ui.view">
        <field name="name">sale.order.tree.inherit.kedoo.fleet.bridge</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="license_plate" optional="show"/>
                <field name="fleet_vehicle_model_id" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="view_sales_order_filter_inherit_kedoo_fleet_bridge" model="ir.ui.view">
        <field name="name">sale.order.search.inherit.kedoo.fleet.bridge</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_view_search_inherit_sale"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="license_plate" string="License Plate"/>
            </xpath>
        </field>
    </record>

    <record id="view_order_form_inherit_kedoo_fleet_bridge_pickup" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.kedoo.fleet.bridge.pickup</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_stock.view_order_form_inherit_sale_stock"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_view_delivery']//field[@name='delivery_count']" position="attributes">
                <attribute name="string">Pickup</attribute>
            </xpath>
        </field>
    </record>
</odoo>
